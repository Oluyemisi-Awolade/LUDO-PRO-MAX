<?xml version="1.0" encoding="utf-8"?>
<!-- android/app/src/main/res/values/styles.xml -->
<resources>
    <!-- Launch theme: shown while Flutter initialises.
         Deep navy matches the app background so there's no white flash. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Normal theme: applied after Flutter draws its first frame. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background</item>
    </style>
</resources>
